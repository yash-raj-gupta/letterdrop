generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Authentication ─────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String    @unique
  emailVerified      DateTime?
  passwordHash       String?
  image              String?
  username           String?   @unique
  brandName          String?
  senderName         String?
  senderEmail        String?
  bio                String?
  plan               Plan      @default(FREE)
  
  // Stripe billing fields
  stripeCustomerId   String?   @unique
  stripeSubscriptionId String?
  stripePriceId      String?
  subscriptionStatus SubscriptionStatus @default(INCOMPLETE)
  currentPeriodEnd   DateTime?
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  subscribers Subscriber[]
  newsletters Newsletter[]
  templates   Template[]
  tags        Tag[]
  apiKeys     ApiKey[]
  customFields CustomField[]
  automations Automation[]
  webhooks    Webhook[]

  @@map("users")
}

// ─── Custom Fields ──────────────────────────────────────────────────────────

model CustomField {
  id          String   @id @default(cuid())
  userId      String
  name        String
  key         String
  type        CustomFieldType
  required    Boolean  @default(false)
  options     Json?    // For select/multiselect: ["option1", "option2"]
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  values      CustomFieldValue[]

  @@unique([userId, key])
  @@map("custom_fields")
}

model CustomFieldValue {
  id            String @id @default(cuid())
  customFieldId String
  subscriberId  String
  value         String

  customField   CustomField @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  subscriber    Subscriber  @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@unique([customFieldId, subscriberId])
  @@map("custom_field_values")
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SELECT
  MULTISELECT
  BOOLEAN
}

// ─── Automations ────────────────────────────────────────────────────────────

model Automation {
  id            String           @id @default(cuid())
  userId        String
  name          String
  trigger       AutomationTrigger
  triggerData   Json             // Trigger-specific config
  actions       AutomationAction[]
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("automations")
}

model AutomationAction {
  id             String   @id @default(cuid())
  automationId   String
  type           AutomationActionType
  order          Int
  delayHours     Int      @default(0) // 0 = immediate
  config         Json     // Action-specific config
  createdAt      DateTime @default(now())

  automation     Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, order])
  @@map("automation_actions")
}

enum AutomationTrigger {
  SUBSCRIBE        // When someone subscribes
  UNSUBSCRIBE      // When someone unsubscribes
  TAG_ADDED        // When tag is added
  TAG_REMOVED      // When tag is removed
  EMAIL_OPENED     // When email is opened
  LINK_CLICKED     // When link is clicked
  DATE_REACHED     // Specific date/time
}

enum AutomationActionType {
  SEND_EMAIL
  ADD_TAG
  REMOVE_TAG
  WAIT
  WEBHOOK
}

// ─── Webhooks ───────────────────────────────────────────────────────────────

model Webhook {
  id         String   @id @default(cuid())
  userId     String
  url        String
  secret     String   // For webhook signature verification
  events     String[] // Array of event types to listen for
  isActive   Boolean  @default(true)
  lastSentAt DateTime?
  failCount  Int      @default(0)
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@map("webhooks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Subscriber Management ──────────────────────────────────────────────────

model Subscriber {
  id             String           @id @default(cuid())
  userId         String
  email          String
  name           String?
  status         SubscriberStatus @default(ACTIVE)
  source         SubscriberSource @default(MANUAL)
  subscribedAt   DateTime         @default(now())
  unsubscribedAt DateTime?
  confirmedAt    DateTime?
  confirmToken   String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags  SubscriberTag[]
  sends Send[]
  customFieldValues CustomFieldValue[]

  @@unique([userId, email])
  @@index([userId, status])
  @@map("subscribers")
}

model Tag {
  id        String   @id @default(cuid())
  userId    String
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscribers SubscriberTag[]

  @@unique([userId, name])
  @@map("tags")
}

model SubscriberTag {
  subscriberId String
  tagId        String

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  tag        Tag        @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([subscriberId, tagId])
  @@map("subscriber_tags")
}

// ─── Newsletter ─────────────────────────────────────────────────────────────

model Newsletter {
  id          String           @id @default(cuid())
  userId      String
  subject     String
  previewText String?
  content     Json?
  htmlContent String?          @db.Text
  slug        String?
  status      NewsletterStatus @default(DRAFT)
  scheduledAt DateTime?
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sends Send[]

  @@unique([userId, slug])
  @@index([userId, status])
  @@map("newsletters")
}

model Send {
  id           String     @id @default(cuid())
  newsletterId String
  subscriberId String
  status       SendStatus @default(QUEUED)
  messageId    String?
  openedAt     DateTime?
  clickedAt    DateTime?
  bouncedAt    DateTime?
  createdAt    DateTime   @default(now())

  newsletter     Newsletter      @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  subscriber     Subscriber      @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  trackingEvents TrackingEvent[]

  @@unique([newsletterId, subscriberId])
  @@index([newsletterId])
  @@map("sends")
}

model TrackingEvent {
  id        String    @id @default(cuid())
  sendId    String
  type      EventType
  url       String?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  send Send @relation(fields: [sendId], references: [id], onDelete: Cascade)

  @@index([sendId])
  @@map("tracking_events")
}

// ─── Templates ──────────────────────────────────────────────────────────────

model Template {
  id        String   @id @default(cuid())
  userId    String
  name      String
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("templates")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  STARTER
  GROWTH
  PRO
}

enum SubscriptionStatus {
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ─── API Keys ───────────────────────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  userId      String
  name        String
  key         String    @unique
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("api_keys")
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  PENDING
}

enum SubscriberSource {
  FORM
  IMPORT
  MANUAL
  API
}

enum NewsletterStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
}

enum SendStatus {
  QUEUED
  SENT
  DELIVERED
  BOUNCED
  FAILED
}

enum EventType {
  OPEN
  CLICK
}
